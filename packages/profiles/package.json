{
  "name": "@beacio/profiles",
  "version": "1.0.0",
  "description": "Pre-built BLE device profiles — heart rate, battery, device info. Typed parsers for Bluetooth GATT characteristics",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./heart-rate": {
      "types": "./dist/heart-rate.d.ts",
      "import": "./dist/heart-rate.mjs",
      "require": "./dist/heart-rate.js"
    },
    "./battery": {
      "types": "./dist/battery.d.ts",
      "import": "./dist/battery.mjs",
      "require": "./dist/battery.js"
    },
    "./device-info": {
      "types": "./dist/device-info.d.ts",
      "import": "./dist/device-info.mjs",
      "require": "./dist/device-info.js"
    },
    "./nordic-uart": {
      "types": "./dist/nordic-uart.d.ts",
      "import": "./dist/nordic-uart.mjs",
      "require": "./dist/nordic-uart.js"
    },
    "./serial-ffe0": {
      "types": "./dist/serial-ffe0.d.ts",
      "import": "./dist/serial-ffe0.mjs",
      "require": "./dist/serial-ffe0.js"
    },
    "./storz-bickel": {
      "types": "./dist/storz-bickel.d.ts",
      "import": "./dist/storz-bickel.mjs",
      "require": "./dist/storz-bickel.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "keywords": [
    "bluetooth",
    "ble",
    "profiles",
    "heart-rate",
    "battery",
    "beacio",
    "webbluetooth",
    "gatt",
    "device-info",
    "web-bluetooth",
    "ios",
    "safari",
    "ai",
    "agent",
    "polyfill",
    "cross-browser",
    "bluetooth-low-energy",
    "web-bluetooth-polyfill",
    "safari-bluetooth",
    "navigator-bluetooth"
  ],
  "author": "wklm",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wklm/beacio-sdk.git",
    "directory": "packages/profiles"
  },
  "homepage": "https://beacio.com/docs#profiles-package",
  "bugs": {
    "url": "https://github.com/wklm/beacio-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@beacio/core": "^1.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/jest": "^30",
    "jest": "^30",
    "jest-environment-jsdom": "^30",
    "ts-jest": "^29",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  }
}
