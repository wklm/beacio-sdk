{
  "name": "@beacio/react",
  "version": "1.0.0",
  "description": "React hooks for Bluetooth Low Energy — useDevice, useScan, useProfile. Real-time BLE data in React",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "sideEffects": [
    "./dist/styles.css"
  ],
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.{ts,tsx}",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "peerDependencies": {
    "@beacio/core": "^1.0.0",
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/web-bluetooth": "^0.0.21",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ts-jest": "^29.4.11",
    "tsup": "^8.0.0",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-native": "npm:typescript@^7.0.2"
  },
  "keywords": [
    "bluetooth",
    "ble",
    "webbluetooth",
    "web-bluetooth",
    "react",
    "react-hooks",
    "safari",
    "beacio",
    "ios",
    "gatt",
    "bluetooth-low-energy",
    "ai",
    "agent",
    "mcp",
    "polyfill",
    "cross-browser",
    "web-bluetooth-polyfill",
    "safari-bluetooth",
    "navigator-bluetooth",
    "react-bluetooth"
  ],
  "author": "wklm",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wklm/beacio-sdk.git",
    "directory": "packages/react-sdk"
  },
  "bugs": {
    "url": "https://github.com/wklm/beacio-sdk/issues"
  },
  "homepage": "https://beacio.com/docs#react-sdk",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
