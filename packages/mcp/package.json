{
  "name": "@beacio/mcp",
  "version": "2.0.0",
  "mcpName": "com.beacio/mcp",
  "description": "MCP server for beacio — unified tools for SDK consumers and extension developers shipping iOS Safari Web Bluetooth.",
  "type": "module",
  "bin": {
    "beacio-mcp": "./dist/cli.js",
    "beacio": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://beacio.com/mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/wklm/beacio-sdk.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/wklm/beacio-sdk/issues"
  },
  "license": "MIT",
  "author": "wklm",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "web-bluetooth",
    "ios",
    "safari",
    "bluetooth",
    "ble",
    "beacio"
  ],
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc",
    "test": "vitest run",
    "dev": "tsx watch src/cli.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@beacio/core": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.0",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-native": "npm:typescript@^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  }
}
