{
  "name": "@ios-web-bluetooth/cli",
  "version": "0.1.1",
  "description": "CLI for WebBLE — init, check, scaffold BLE profiles for web apps",
  "bin": {
    "ioswebble": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts",
    "dev": "tsup src/index.ts --format cjs --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ios",
    "safari",
    "bluetooth",
    "ble",
    "web-bluetooth",
    "webbluetooth",
    "cli",
    "webble",
    "gatt",
    "scaffold",
    "ai",
    "agent",
    "polyfill",
    "cross-browser",
    "safari-bluetooth",
    "navigator-bluetooth"
  ],
  "author": "wklm",
  "repository": {
    "type": "git",
    "url": "https://github.com/wklm/ioswebble-sdk.git",
    "directory": "packages/cli"
  },
  "homepage": "https://ioswebble.com",
  "bugs": {
    "url": "https://github.com/wklm/ioswebble-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@ios-web-bluetooth/detect": "^0.1.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  }
}
