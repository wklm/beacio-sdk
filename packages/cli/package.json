{
  "name": "@beacio/cli",
  "version": "1.0.0",
  "description": "CLI for beacio — init, check, scaffold BLE profiles for web apps",
  "bin": {
    "beacio": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts",
    "dev": "tsup src/index.ts --format cjs --watch",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ios",
    "safari",
    "bluetooth",
    "ble",
    "web-bluetooth",
    "webbluetooth",
    "cli",
    "beacio",
    "gatt",
    "scaffold",
    "ai",
    "agent",
    "polyfill",
    "cross-browser",
    "safari-bluetooth",
    "navigator-bluetooth"
  ],
  "author": "wklm",
  "repository": {
    "type": "git",
    "url": "https://github.com/wklm/beacio-sdk.git",
    "directory": "packages/cli"
  },
  "homepage": "https://beacio.com",
  "bugs": {
    "url": "https://github.com/wklm/beacio-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@beacio/detect": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
