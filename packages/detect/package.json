{
  "name": "@beacio/detect",
  "version": "1.0.0",
  "description": "Detect beacio Safari extension on iOS. Auto-show install banner when extension not found",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./auto": {
      "types": "./dist/auto.d.ts",
      "import": "./dist/auto.mjs",
      "require": "./dist/auto.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "AGENTS.md",
    "SKILL.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "keywords": [
    "ios",
    "safari",
    "bluetooth",
    "ble",
    "web-bluetooth",
    "webbluetooth",
    "beacio",
    "extension",
    "detect",
    "install-banner",
    "ai",
    "agent",
    "mcp",
    "polyfill",
    "cross-browser",
    "safari-bluetooth",
    "navigator-bluetooth"
  ],
  "author": "wklm",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wklm/beacio-sdk.git",
    "directory": "packages/detect"
  },
  "homepage": "https://beacio.com/docs#detect-package",
  "bugs": {
    "url": "https://github.com/wklm/beacio-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "@beacio/core": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@beacio/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "react": "^19.2.7",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  }
}
